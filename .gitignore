# ---- Secrets / environment ----
# .env holds the real SECRET_KEY and DB password — never commit it.
.env
.env.*
!.env.sample

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/

# ---- Django ----
*.log
*.sqlite3
db.sqlite3
# Collected static (output of collectstatic) and user uploads — generated, not source.
# Note: backend/static/ (hand-written assets) is intentionally NOT ignored.
backend/staticfiles/
backend/mediafiles/
local_settings.py

# ---- Frontend (Node) ----
node_modules/
frontend/dist/
frontend/build/
frontend/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Docker ----
# Local dev-only compose overrides (bind mounts, --reload). Never deployed.
docker-compose.override.yml

# ---- Celery ----
# Celery beat's PersistentScheduler db (runtime artifact; written into the
# bind-mounted ./backend in dev). Never source.
celerybeat-schedule
celerybeat-schedule*
celerybeat.pid

# ---- Claude Code ----
# Ignore all .claude/ directories entirely (root and nested, e.g. backend/.claude/).
.claude/

# ---- IDE / editor ----
.idea/
.vscode/
*.swp
*~

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
