# Normalize line endings: store LF in the repo, check out native on each OS.
* text=auto eol=lf

# Scripts that must keep their platform line endings to run.
*.sh   text eol=lf
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Treat these as binary (no diff, no eol conversion).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.sqlite3 binary
