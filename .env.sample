# Django environment settings — template.
# Copy to .env and fill in real values:  cp .env.sample .env
# Generate a secret key (avoids $ and ` so .env interpolation can't mangle it):
#   python -c "import secrets; print(''.join(secrets.choice('abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#%^&*(-_=+)') for _ in range(64)))"

# --- Core ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Include the public (nginx) origin, e.g. http://localhost:9005
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:9005,http://127.0.0.1:9005,http://localhost,http://127.0.0.1

# --- Database ---
# DB_ENGINE: "sqlite3" (default) or "postgresql".
DB_ENGINE=sqlite3
DB_NAME=dashboard
DB_USER=dashboard
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Redis (Channels layer + cache) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Email ---
# Leave EMAIL_HOST blank to print emails to the console (dev default).
# Set it to switch to the SMTP backend; the rest apply only then.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=dashboard@example.com
